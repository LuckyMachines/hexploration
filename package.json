{
  "name": "xenovoya",
  "version": "0.2.0",
  "description": "On-chain multiplayer explore & escape game.",
  "scripts": {
    "build": "forge build",
    "test": "forge test",
    "worker": "node scripts/xenovoya-worker.mjs",
    "enable-mock-vrf": "node scripts/enable-mock-vrf.mjs",
    "check-status": "node scripts/check-xenovoya-status.mjs",
    "dev": "cd app && npm run dev",
    "local": "node scripts/run-local-stack.mjs",
    "local:solo": "node scripts/run-local-stack.mjs --solo",
    "local:multi": "node scripts/run-local-stack.mjs --multi",
    "local:multi:3": "node scripts/run-local-stack.mjs --multi --players=3",
    "local:multi:4": "node scripts/run-local-stack.mjs --multi --players=4",
    "local:join": "node scripts/join-local-game.mjs",
    "local:bots": "node scripts/register-bots.mjs",
    "local:auto-bots": "node scripts/auto-bots.mjs",
    "sim": "node scripts/gameplay-simulator.mjs",
    "sim:balanced": "node scripts/gameplay-simulator.mjs --turns=12 --strategy=balanced",
    "sim:risky": "node scripts/gameplay-simulator.mjs --turns=12 --strategy=risky",
    "sim:batch": "node scripts/gameplay-simulator.mjs --scenario=benchmark --batch=3",
    "sim:golden": "node scripts/gameplay-simulator.mjs --scenario=benchmark --batch=5",
    "sim:baseline": "node scripts/gameplay-simulator.mjs --scenario=benchmark --batch=5 --save-baseline",
    "sim:compare": "node scripts/gameplay-simulator.mjs --scenario=benchmark --batch=5 --baseline",
    "sim:autotune": "node scripts/simulator-autotune.mjs --scenario=benchmark --batch=3",
    "sim:autotune:dry": "node scripts/simulator-autotune.mjs --dry-run",
    "scenario:create": "node scripts/scenario-designer.mjs create",
    "scenario:list": "node scripts/scenario-designer.mjs list",
    "scenario:show": "node scripts/scenario-designer.mjs show",
    "scenario:validate": "node scripts/scenario-designer.mjs validate",
    "scenario:run": "node scripts/scenario-designer.mjs run",
    "scenario:run-pack": "node scripts/scenario-designer.mjs run-pack",
    "scenario:autotune": "node scripts/simulator-autotune.mjs --scenario=benchmark --batch=3",
    "scenario:test": "node --test scripts/scenario-utils.test.mjs",
    "oracle:run": "node scripts/gameplay-oracle.mjs run",
    "oracle:scenario": "node scripts/gameplay-oracle.mjs scenario",
    "oracle:pack": "node scripts/gameplay-oracle.mjs pack",
    "oracle:project": "node scripts/gameplay-oracle.mjs project",
    "oracle:latest": "node scripts/gameplay-oracle.mjs latest",
    "oracle:doctor": "node scripts/gameplay-oracle.mjs doctor",
    "oracle:ci": "node scripts/gameplay-oracle.mjs ci",
    "oracle:test": "node --test scripts/gameplay-oracle-utils.test.mjs",
    "setup:forge": "node scripts/scenario-setup-forge.mjs forge",
    "setup:validate": "node scripts/scenario-setup-forge.mjs validate",
    "setup:doctor": "node scripts/scenario-setup-forge.mjs doctor",
    "setup:matrix": "node scripts/scenario-setup-forge.mjs matrix",
    "setup:explain": "node scripts/scenario-setup-forge.mjs explain",
    "setup:author": "node scripts/scenario-setup-forge.mjs author",
    "setup:variant": "node scripts/scenario-setup-forge.mjs variant",
    "setup:backlog": "node scripts/scenario-setup-forge.mjs backlog",
    "setup:test": "node --test scripts/setup-forge-utils.test.mjs",
    "test:e2e:anvil": "node scripts/run-anvil-e2e.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LuckyMachines/xenovoya.git"
  },
  "author": "Max Meier",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/LuckyMachines/xenovoya/issues"
  },
  "homepage": "https://github.com/LuckyMachines/xenovoya#readme",
  "dependencies": {
    "@luckymachines/game-core": "file:../game-core",
    "@luckymachines/autoloop": "file:../AUTOLOOP_STUFF/autoloop"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "viem": "^2.46.2"
  }
}
